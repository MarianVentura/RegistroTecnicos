@page "/Tecnico/Edit"
@page "/Tecnico/Edit/{TecnicoId:int}"
@inject TecnicoService TecnicoService
@inject NavigationManager NavigationManager
@using RegistroTecnicos.Models

<EditForm Model="Tecnico" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <div class="card shadow-lg border-0 rounded" style="background-color: #f8f9fa;">
        <div class="card-header bg-primary text-white" style="text-align: center;">
            <h3> <i class="fas fa-clipboard-list"></i> Editar Técnicos</h3>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <label for="Nombres" class="form-label">Nombres:</label>
                <InputText @bind-Value="Tecnico.Nombres" class="form-control" />
                <ValidationMessage For="@(() => Tecnico.Nombres)" />
            </div>

            <!-- Puedes agregar más campos según sea necesario -->

        </div>

        <div class="card-footer bg-light d-flex justify-content-center mt-3">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-primary ml-2" @onclick="Nuevo"><span class="bi bi-plus"></span> Nuevo </button>
                <button type="submit" class="btn btn-outline-success ml-2"><span class="bi bi-check-circle-fill"></span> Guardar </button>
                <button type="button" class="btn btn-outline-danger ml-2" @onclick="Eliminar"><span class="bi bi-trash-fill"></span> Eliminar </button>
                <a type="button" href="/Tecnico/Index/" class="btn btn-outline-danger"><span class="bi bi-arrow-bar-left"></span> Retroceder </a>
            </div>
        </div>
    </div>
</EditForm>


@code {
    [Parameter]
    public int TecnicoId { get; set; }
    public Models.Tecnicos Tecnico { get; set; } = new Models.Tecnicos();
    private bool Existe = false;

    protected override async Task OnInitializedAsync()
    {
        if (TecnicoId != 0)
        {
            await Buscar();
        }
    }

    public void Nuevo()
    {
            Tecnico = new Models.Tecnicos();
        Existe = false;
    }

    public async Task Buscar()
    {
        Existe = false;
        Tecnico = await TecnicoService.BuscarTecnico(TecnicoId);

        if (Tecnico == null)
        {
            Nuevo();
        }
    }

    public async Task Guardar()
    {
        if (Validar())
        {
            return;
        }

        var guardo = await TecnicoService.GuardarTecnico(Tecnico);
        if (guardo)
        {
            Nuevo();
        }
    }

    public async Task Eliminar()
    {
        await TecnicoService.EliminarTecnico(Tecnico.TecnicoId);
        Nuevo();
    }

    public bool Validar()
    {
        // Aquí puedes agregar lógica de validación según tus necesidades
        // Por ejemplo, puedes verificar si ya existe un técnico con el mismo nombre

        return false; // En este ejemplo, siempre retornamos false
    }
}
