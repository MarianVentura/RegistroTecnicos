@page "/Tecnico/Index"

@inject TecnicoService TecnicoService
@rendermode InteractiveServer

<EditForm Model="ListaTecnicos" class="border shadow-lg p-3 rounded">
    <div class="card-header bg-primary text-white text-center py-2 rounded">
        <h3 style="font-weight: bold;" class="mb-0 font-weight-bold">Consulta Técnicos</h3>
    </div>
    <div class="card-body">
        <div class="row mb-3 align-items-end">
            <div class="col-md-3">
                <label for="Filtro" class="form-label">Filtrar por:</label>
                <select @bind="filtro" class="form-select">
                    <option value="id">ID</option>
                    <option value="nombre">Nombre</option>
                    <!-- Agrega más opciones de filtro según sea necesario -->
                </select>
            </div>
            <div class="col-md-6">
                <label for="ValorFiltro" class="form-label">Búsqueda:</label>
                <div class="input-group">
                    <input @bind="valorFiltro" class="form-control" placeholder="Buscar" />
                    <button @onclick="Buscar" class="btn btn-outline-primary" type="button">
                        <span class="bi bi-search"></span> Buscar
                    </button>
                </div>
            </div>
            <div class="col-md-3 text-end">
                <a href="/Tecnico/Create" class="btn btn-success" type="button"><span class="bi bi-floppy"></span> Crear </a>
            </div>
        </div>
    </div>
    <table class="table table-bordered text-center">
        <thead class="bg-primary text-white">
            <tr>
                <th>TecnicoId</th>
                <th>Nombre</th>
                <!-- Agrega más encabezados de columna según sea necesario -->
                <th>Ver</th>
                <th>Editar</th>
                <th>Eliminar</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tecnico in ListaTecnicos)
            {
                <tr>
                    <td>@tecnico.TecnicoId</td>
                    <td>@tecnico.Nombres</td>
                    <!-- Agrega más columnas según sea necesario -->
                    <td>
                        <a href="/Tecnico/Details/@tecnico.TecnicoId" style="border: none; background-color: transparent;" class="btn-detalle">
                            <span class="bi bi-info-circle-fill" style="font-size: 2rem;"></span>
                        </a>
                    </td>
                    <td>
                        <a href="/Tecnico/Edit/@tecnico.TecnicoId" style="border: none; background-color: transparent;" class="btn-editar">
                            <span class="bi bi-marker-tip" style="font-size: 2rem;"></span>
                        </a>
                    </td>
                    <td>
                        <a href="/Tecnico/Delete/@tecnico.TecnicoId" style="border: none; background-color: transparent;" class="btn-eliminar">
                            <span class="bi bi-dash-circle-fill" style="font-size: 2rem;"></span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</EditForm>


@code {
    public List<Tecnico> ListaTecnicos = new List<Tecnico>();
    private string filtro = "id";
    private string valorFiltro = "";

    protected override async Task OnInitializedAsync()
    {
        ListaTecnicos = await TecnicoService.ListarTecnicos();
    }

    private async Task Buscar()
    {
        if (valorFiltro.Trim() != "")
        {
            if (filtro == "id" && int.TryParse(valorFiltro, out int TecnicoId))
            {
                ListaTecnicos = (await TecnicoService.ListarTecnicos()).Where(t => t.TecnicoId == TecnicoId).ToList();
            }
            else if (filtro == "nombre")
            {
                ListaTecnicos = (await TecnicoService.ListarTecnicos()).Where(t => t.Nombres == valorFiltro).ToList();
            }
            // Agrega más condiciones según sea necesario para otros filtros
        }
        else
        {
            ListaTecnicos = await TecnicoService.ListarTecnicos();
        }
    }
}
